        oi.order_id,
        o.customer_id,
        o.restaurant_id,
        o.order_time,
        o.delivery_time,
        o.status,
        o.total_amount,
        oi.item_name,
        oi.quantity,
        oi.unit_price,
        oi.quantity * oi.unit_price as item_total
    from order_items oi
    left join orders o
        on oi.order_id = o.order_id

)

select *
from joined
  )
